{
  "name": "vector-platform-desktop",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "main": "electron/main.js",
  "description": "Vector Platform Desktop Application",
  "author": "Vector Team",
  "repository": "https://github.com/ThisaraChandima/vector-platform-desktop",
  "build": {
    "appId": "com.vector.platform",
    "publish": {
      "provider": "github",
      "owner": "ThisaraChandima",
      "repo": "vector-platform-desktop"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      ".env",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "build:all": "vite build && electron-builder -mw",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.110.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "groq-sdk": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  }
}
